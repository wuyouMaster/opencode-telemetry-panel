{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenCode Telemetry Panel",
  "identifier": "ai.opencode.telemetry-panel",
  "mainBinaryName": "OpenCodeTelemetryPanel",
  "version": "../package.json",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenCode Telemetry Panel",
        "width": 480,
        "height": 720,
        "minWidth": 380,
        "minHeight": 520,
        "resizable": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
